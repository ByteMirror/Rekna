{
  "name": "@linea/desktop",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "build:renderer": "vite build --config ../../vite.config.ts",
    "dev": "bun run build:renderer && LINEA_DISABLE_NATIVE_COMPLETION_OVERLAY=1 electrobun dev",
    "dev:hmr": "concurrently \"vite --config ../../vite.config.ts --port 5173\" \"LINEA_DISABLE_NATIVE_COMPLETION_OVERLAY=1 electrobun dev --watch\""
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@linea/app-shell": "workspace:*",
    "@linea/calc-engine": "workspace:*",
    "@linea/shared": "workspace:*",
    "@linea/storage": "workspace:*",
    "codemirror": "^6.0.2",
    "electrobun": "^1.16.0",
    "framer-motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "vite": "^7.1.3"
  }
}
