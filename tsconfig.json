{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/desktop/src/browser/*"],
      "@linea/app-core": ["packages/app-core/src/index.ts"],
      "@linea/calc-engine": ["packages/calc-engine/src/index.ts"],
      "@linea/design-tokens": ["packages/design-tokens/src/index.ts"],
      "@linea/shared": ["packages/shared/src/index.ts"],
      "@linea/storage": ["packages/storage/src/index.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "types/**/*.d.ts",
    "electrobun.config.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "apps/native/**/*"
  ]
}
